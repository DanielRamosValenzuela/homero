{
  "schemaVersion": 1,
  "projectName": "__PROJECT_NAME__",
  "packageManager": "pnpm",
  "product": {
    "portfolio": "Falabella Seguros",
    "designSystem": "Tomaco"
  },
  "commands": {
    "lint": "pnpm lint",
    "typecheck": "pnpm exec tsc --noEmit",
    "test": "pnpm test",
    "e2e": "pnpm exec playwright test"
  },
  "paths": {
    "uiRoot": "src/ui",
    "stepRoot": "src/app",
    "serverActionsRoot": "src/actions",
    "storesRoot": "src/store"
  },
  "figma": {
    "mcpExampleFile": "mcp.example.json",
    "requiredForVisualChanges": true,
    "visualDiffThreshold": 0.01
  },
  "playwright": {
    "cliCommand": "pnpm exec playwright-cli",
    "evidenceRoot": "features/<id>/evidence",
    "testCommand": "pnpm exec playwright test"
  },
  "contracts": {
    "mode": "contract-draft",
    "format": "examples",
    "source": "TBD",
    "mockStrategy": "fixtures",
    "mockLocation": "src/mocks",
    "states": "success, loading, empty, validation error, business error, network/server error",
    "sensitiveDataPolicy": "anonymized-only"
  },
  "workspace": {
    "featureBranchPrefix": "feature/",
    "humanCommitRequired": true,
    "allowHomeroCommit": false,
    "allowHomeroPush": false,
    "allowHomeroPullRequest": false,
    "allowHomeroMerge": false
  },
  "agents": {
    "workflow": "discover -> specify -> plan -> tasks -> implement -> verify -> converge",
    "coordinator": "homero-coordinator",
    "roles": [
      "homero-discovery",
      "homero-figma",
      "homero-contracts",
      "homero-planner",
      "homero-implementer",
      "homero-reviewer"
    ],
    "modelPolicy": "use client default unless the team records a specific model"
  }
}
